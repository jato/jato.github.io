---
import Layout from '../../components/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const experiments = await getCollection(
    'experiments',
    ({ data }) => !data.draft,
  );
  return experiments.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} · Experiments · James Allen Brown`}
  description={entry.data.summary}
>
  <article class="experiment">
    <p class="back"><a href="/experiments/">← Experiments</a></p>

    <header class="experiment-head">
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.summary}</p>
      {
        (entry.data.year || entry.data.sourceUrl) && (
          <p class="meta">
            {entry.data.year && <span>{entry.data.year}</span>}
            {entry.data.year && entry.data.sourceUrl && (
              <span aria-hidden="true">·</span>
            )}
            {entry.data.sourceUrl && (
              <a href={entry.data.sourceUrl}>
                {entry.data.sourceUrl.replace('https://', '')}
              </a>
            )}
          </p>
        )
      }
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .experiment {
    max-width: var(--measure);
  }

  .back {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-6);
  }
  .back a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .back a:hover {
    text-decoration: underline;
  }

  .experiment-head {
    margin-bottom: var(--space-8);
  }

  .experiment-head h1 {
    margin-bottom: var(--space-4);
  }

  .lede {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 60, 'SOFT' 50;
    font-size: clamp(1.15rem, 0.6vw + 1rem, 1.3rem);
    font-style: italic;
    line-height: 1.45;
    color: var(--color-ink-soft);
    margin-bottom: var(--space-5);
  }

  .meta {
    color: var(--color-ink-muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .meta span[aria-hidden] {
    margin: 0 var(--space-2);
    opacity: 0.5;
  }
  .meta a {
    color: var(--color-ink-soft);
  }

  .body {
    color: var(--color-ink);
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .body :global(p) {
    max-width: var(--measure);
    margin-bottom: var(--space-5);
  }

  .body :global(code) {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.92em;
    background: rgba(21, 24, 43, 0.06);
    padding: 1px 5px;
    border-radius: 3px;
  }

</style>
