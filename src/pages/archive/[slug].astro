---
import Layout from '../../components/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const projects = await getCollection('archiveProjects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} — Archive — James Allen Brown`}
  description={entry.data.summary}
>
  <article class="prose">
    <p class="back"><a href="/archive/">← Archive</a></p>

    <header class="article-head">
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.summary}</p>

      <dl class="meta">
        <div>
          <dt>Year</dt>
          <dd>{entry.data.year}</dd>
        </div>
        <div>
          <dt>Role</dt>
          <dd>{entry.data.role}</dd>
        </div>
        {
          entry.data.stack.length > 0 && (
            <div>
              <dt>Stack</dt>
              <dd>{entry.data.stack.join(' · ')}</dd>
            </div>
          )
        }
        {
          entry.data.sourceUrl && (
            <div>
              <dt>Source</dt>
              <dd>
                <a href={entry.data.sourceUrl}>{entry.data.sourceUrl.replace('https://', '')}</a>
              </dd>
            </div>
          )
        }
      </dl>
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .prose {
    max-width: var(--measure);
  }

  .back {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-8);
  }
  .back a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .back a:hover {
    text-decoration: underline;
  }

  .article-head {
    margin-bottom: var(--space-8);
  }

  .article-head h1 {
    margin-bottom: var(--space-4);
  }

  .lede {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 60, 'SOFT' 50;
    font-size: clamp(1.15rem, 0.8vw + 1rem, 1.4rem);
    line-height: 1.45;
    color: var(--color-ink);
    margin-bottom: var(--space-6);
  }

  .meta {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding: var(--space-5) 0;
    margin: 0;
  }
  .meta div {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-4);
  }
  .meta dt {
    color: var(--color-ink-muted);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0;
  }
  .meta dd {
    margin: 0;
    color: var(--color-ink);
    font-size: 0.95rem;
  }
  .meta a {
    color: inherit;
  }

  .body {
    color: var(--color-ink);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .body :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-5) 0;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .body :global(blockquote strong) {
    color: var(--color-ink);
  }

  .body :global(p) {
    max-width: var(--measure);
  }
</style>
