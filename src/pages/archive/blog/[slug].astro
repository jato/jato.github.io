---
import Layout from '../../../components/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('archivePosts');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${entry.data.title} · Archive Blog · James Allen Brown`}
  description={entry.data.subtitle ?? entry.data.title}
>
  <article class="prose">
    <p class="back"><a href="/archive/blog/">← Archive Blog</a></p>

    <aside class="archive-banner">
      From an earlier era. This post was originally published in
      <time datetime={entry.data.publishedAt.toISOString()}>
        {fmt.format(entry.data.publishedAt)}
      </time> and is preserved here as written.
    </aside>

    <header class="article-head">
      <h1>{entry.data.title}</h1>
      {entry.data.subtitle && <p class="subtitle">{entry.data.subtitle}</p>}
      <time class="pub" datetime={entry.data.publishedAt.toISOString()}>
        {fmt.format(entry.data.publishedAt)}
      </time>
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .prose {
    max-width: var(--measure);
  }

  .back {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-5);
  }
  .back a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .back a:hover {
    text-decoration: underline;
  }

  .archive-banner {
    background: rgba(77, 33, 104, 0.06);
    border-left: 2px solid var(--color-accent);
    padding: var(--space-3) var(--space-4);
    margin: 0 0 var(--space-8);
    color: var(--color-ink-soft);
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .archive-banner time {
    font-style: italic;
  }

  .article-head {
    margin-bottom: var(--space-8);
  }

  .article-head h1 {
    margin-bottom: var(--space-3);
  }

  .subtitle {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 60, 'SOFT' 30;
    font-style: italic;
    font-size: clamp(1.1rem, 0.6vw + 1rem, 1.3rem);
    color: var(--color-ink-soft);
    margin: 0 0 var(--space-4);
  }

  .pub {
    color: var(--color-ink-muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }

  .body {
    color: var(--color-ink);
    font-size: 1.05rem;
    line-height: 1.7;
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 14, 'SOFT' 30;
  }

  .body :global(p) {
    max-width: var(--measure);
    margin-bottom: var(--space-5);
  }

</style>
