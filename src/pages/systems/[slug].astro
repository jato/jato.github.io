---
import Layout from '../../components/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const systems = await getCollection('systems', ({ data }) => !data.draft);
  return systems.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} · Systems · James Allen Brown`}
  description={entry.data.summary}
>
  <article class="system">
    <p class="back"><a href="/systems/">← Systems</a></p>

    <header class="system-head">
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.summary}</p>
      <dl class="meta">
        {
          entry.data.year && (
            <div>
              <dt>Year</dt>
              <dd>{entry.data.year}</dd>
            </div>
          )
        }
        <div>
          <dt>Status</dt>
          <dd>{entry.data.status}</dd>
        </div>
        {
          entry.data.tags.length > 0 && (
            <div>
              <dt>Tags</dt>
              <dd>{entry.data.tags.join(', ')}</dd>
            </div>
          )
        }
      </dl>
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .system {
    max-width: var(--measure);
  }

  .back {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-6);
  }
  .back a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .back a:hover {
    text-decoration: underline;
  }

  .system-head {
    margin-bottom: var(--space-8);
  }

  .system-head h1 {
    margin-bottom: var(--space-4);
  }

  .lede {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 60, 'SOFT' 50;
    font-size: clamp(1.15rem, 0.6vw + 1rem, 1.35rem);
    line-height: 1.45;
    color: var(--color-ink);
    margin-bottom: var(--space-6);
  }

  .meta {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding: var(--space-4) 0;
    margin: 0;
  }
  .meta div {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-4);
  }
  .meta dt {
    color: var(--color-ink-muted);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0;
  }
  .meta dd {
    margin: 0;
    color: var(--color-ink);
    font-size: 0.9rem;
    text-transform: capitalize;
  }

  .body {
    color: var(--color-ink);
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .body :global(p) {
    max-width: var(--measure);
    margin-bottom: var(--space-5);
  }

  .body :global(strong) {
    font-weight: 600;
  }

  .body :global(em) {
    font-style: italic;
  }

  .body :global(code) {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.92em;
    background: rgba(21, 24, 43, 0.06);
    padding: 1px 5px;
    border-radius: 3px;
  }

</style>
