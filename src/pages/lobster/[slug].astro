---
import Layout from '../../components/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const docs = await getCollection('legal');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${entry.data.title} · ${entry.data.app}`}
  description={entry.data.summary}
>
  <article class="legal">
    <p class="back"><a href="/about/">← About</a></p>

    <header class="legal-head">
      <p class="eyebrow">{entry.data.app}</p>
      <h1>{entry.data.title}</h1>
      <p class="meta">
        Last updated <time datetime={entry.data.lastUpdated.toISOString()}>
          {fmt.format(entry.data.lastUpdated)}
        </time>
      </p>
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .legal {
    max-width: var(--measure);
  }

  .back {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-6);
  }
  .back a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .back a:hover {
    text-decoration: underline;
  }

  .legal-head {
    margin-bottom: var(--space-8);
  }

  .eyebrow {
    color: var(--color-ink-muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 var(--space-3);
  }

  .legal-head h1 {
    margin-bottom: var(--space-4);
    font-size: clamp(2rem, 2vw + 1.2rem, 2.6rem);
  }

  .meta {
    color: var(--color-ink-muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .body {
    color: var(--color-ink);
    font-size: 1rem;
    line-height: 1.65;
  }

  .body :global(h2) {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 60, 'SOFT' 30;
    font-size: 1.3rem;
    font-weight: 500;
    margin: var(--space-8) 0 var(--space-3);
    color: var(--color-ink);
  }

  .body :global(p) {
    max-width: var(--measure);
    margin: 0 0 var(--space-4);
  }

  .body :global(ul),
  .body :global(ol) {
    max-width: var(--measure);
    margin: 0 0 var(--space-5);
    padding-left: var(--space-5);
  }

  .body :global(li) {
    margin-bottom: var(--space-2);
  }

  .body :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  .body :global(em) {
    font-style: italic;
  }

  .body :global(a) {
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .body :global(code) {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.9em;
    background: rgba(21, 24, 43, 0.06);
    padding: 1px 5px;
    border-radius: 3px;
  }

  .body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-5) 0;
    font-size: 0.92rem;
  }

  .body :global(th),
  .body :global(td) {
    text-align: left;
    vertical-align: top;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-rule);
  }

  .body :global(th) {
    font-weight: 600;
    color: var(--color-ink);
    background: rgba(21, 24, 43, 0.03);
  }

  /* Tables overflow gracefully on narrow viewports */
  .body :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
</style>
