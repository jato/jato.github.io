---
import Layout from '../components/Layout.astro';
---

<Layout title="James Allen Brown">
  <section class="intro">
    <h1>James Allen Brown</h1>
    <p class="lede">hello.</p>
    <p class="lede-meta">
      <a href="/writing/">Read the writing</a>
      <span aria-hidden="true">·</span>
      <a href="/systems/">See the systems</a>
    </p>
  </section>

  <hr class="rule" />

  <section class="now">
    <h2>Now</h2>
    <p class="editorial">
      Engineering leadership. Crisis management. Building the systems, and
      the teams, that hold steady when everything else doesn't.
    </p>
  </section>

  <section class="threads">
    <h2>Threads</h2>
    <ul class="thread-list">
      <li>
        <a href="/writing/" class="thread-title">Writing</a>
        <p>Essays on operational judgment, AI-native workflows, and humane technology.</p>
      </li>
      <li>
        <a href="/systems/" class="thread-title">Systems</a>
        <p>Operating models for incident response, escalation, and metrics. Written down.</p>
      </li>
      <li>
        <a href="/experiments/" class="thread-title">Experiments</a>
        <p>Smaller things: visual studies, AI workflow tools, design explorations.</p>
      </li>
      <li>
        <a href="/archive/" class="thread-title">Archive</a>
        <p>Earlier work. Bootcamp-era projects and posts, kept for the record.</p>
      </li>
    </ul>
  </section>
</Layout>

<style>
  .intro {
    margin-bottom: var(--space-8);
  }

  .intro h1 {
    margin-bottom: var(--space-5);
  }

  .lede {
    font-size: clamp(1.2rem, 1vw + 1.05rem, 1.5rem);
    line-height: 1.4;
    color: var(--color-ink);
    margin-bottom: var(--space-5);
    max-width: var(--measure-narrow);
  }

  .lede-meta {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }

  .lede-meta span {
    margin: 0 var(--space-2);
    opacity: 0.55;
  }

  .rule {
    border: 0;
    height: 1px;
    background: var(--color-rule);
    margin: var(--space-8) 0;
  }

  .now,
  .threads {
    margin-bottom: var(--space-10);
  }

  .now h2,
  .threads h2 {
    color: var(--color-ink-muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: var(--space-5);
  }

  .thread-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
  }

  .thread-list li {
    display: grid;
    gap: var(--space-2);
  }

  .thread-title {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 90, 'SOFT' 40, 'WONK' 0;
    font-weight: 460;
    font-size: 1.6rem;
    text-decoration: none;
    color: var(--color-ink);
    line-height: 1.1;
    letter-spacing: -0.01em;
    overflow-wrap: break-word;
  }

  .thread-title:hover {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .thread-list p {
    color: var(--color-ink-soft);
    font-size: 1rem;
    max-width: var(--measure-narrow);
    margin: 0;
  }
</style>
