---
import Layout from '../../components/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const essays = await getCollection('essays', ({ data }) => !data.draft);
  return essays.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${entry.data.title} · Writing · James Allen Brown`}
  description={entry.data.summary}
>
  <article class="essay">
    <p class="back"><a href="/writing/">← Writing</a></p>

    <header class="essay-head">
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.summary}</p>
      <p class="meta">
        <time datetime={entry.data.publishedAt.toISOString()}>
          {fmt.format(entry.data.publishedAt)}
        </time>
        {
          entry.data.tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              <span class="tags">{entry.data.tags.join(', ')}</span>
            </>
          )
        }
      </p>
    </header>

    <div class="body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .essay {
    max-width: var(--measure);
  }

  .back {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-6);
  }
  .back a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .back a:hover {
    text-decoration: underline;
  }

  .essay-head {
    margin-bottom: var(--space-8);
  }

  .essay-head h1 {
    margin-bottom: var(--space-4);
  }

  .lede {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 60, 'SOFT' 50;
    font-style: italic;
    font-size: clamp(1.15rem, 0.6vw + 1rem, 1.3rem);
    line-height: 1.45;
    color: var(--color-ink-soft);
    margin-bottom: var(--space-5);
  }

  .meta {
    color: var(--color-ink-muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .meta span[aria-hidden] {
    margin: 0 var(--space-2);
    opacity: 0.5;
  }

  .body {
    color: var(--color-ink);
    font-size: 1.08rem;
    line-height: 1.7;
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 14, 'SOFT' 30;
  }

  .body :global(p) {
    max-width: var(--measure);
    margin-bottom: var(--space-5);
  }

  .body :global(strong) {
    font-weight: 600;
  }

  .body :global(em) {
    font-style: italic;
  }

  .body :global(code) {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.92em;
    background: rgba(21, 24, 43, 0.06);
    padding: 1px 5px;
    border-radius: 3px;
  }

</style>
