---
// Tiny birds that occasionally drift past in the far background.
// Pure CSS: no JS. Long durations + staggered (sometimes negative) delays
// give the "occasional" feel — sometimes there's nothing in the sky, then a bird,
// then maybe two. Flight path includes a gentle vertical sway so the motion
// doesn't look mechanical. Wing-flap is a separate transform on the inner SVG.
//
// Sits BEHIND the cloud layer (clouds will pass over the birds, occluding them
// briefly — exactly what you want).
---

<div class="birds" aria-hidden="true" transition:persist="birds">
  <svg width="0" height="0" style="position: absolute" focusable="false">
    <!-- Four distinct silhouettes. All share the same 20x8 viewBox so sizing
         and the wing-flap (scaleY) animation work uniformly. -->

    <!-- Gull: sharp upturned M, dramatic wing peaks. -->
    <symbol id="bird-gull" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 Q 4.5,0.5 10,5 Q 15.5,0.5 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </symbol>

    <!-- Glider: gentle, soaring hawk. Wings barely raised. -->
    <symbol id="bird-glider" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 Q 5,2.2 10,4.5 Q 15,2.2 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </symbol>

    <!-- Swallow: angular zigzag, sharp wing tips, fast and pointy. -->
    <symbol id="bird-swallow" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 L 5,1.5 L 10,5 L 15,1.5 L 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="miter"
        stroke-miterlimit="2"
      />
    </symbol>

    <!-- Sparrow: small bird with a body. Two short wing arcs + a body mark. -->
    <symbol id="bird-sparrow" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 Q 4,2 8.5,4.5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
      />
      <path
        d="M 11.5,4.5 Q 16,2 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
      />
      <ellipse cx="10" cy="4.7" rx="1.6" ry="1.2" fill="currentColor" />
    </symbol>
  </svg>

  <div class="bird-flight bird-flight--1">
    <svg class="bird"><use href="#bird-gull" /></svg>
  </div>
  <div class="bird-flight bird-flight--2">
    <svg class="bird"><use href="#bird-swallow" /></svg>
  </div>
  <div class="bird-flight bird-flight--3">
    <svg class="bird"><use href="#bird-glider" /></svg>
  </div>
  <div class="bird-flight bird-flight--4">
    <svg class="bird"><use href="#bird-sparrow" /></svg>
  </div>
</div>

<style>
  .birds {
    position: fixed;
    inset: 0 0 35% 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
    color: var(--color-sky-deep);
  }

  .bird-flight {
    position: absolute;
    left: 0;
    opacity: 0;
    will-change: transform, opacity;
  }

  .bird {
    display: block;
    width: 22px;
    height: auto;
    transform-origin: center;
  }

  /* Four lanes — different heights, sizes, directions. Speeds and delays
     are applied via Web Animations API in the script below (so they survive
     ClientRouter navigations). */
  .bird-flight--1 { top: 22%; }
  .bird-flight--2 { top: 11%; }
  .bird-flight--2 .bird { width: 17px; }
  .bird-flight--3 { top: 30%; }
  .bird-flight--3 .bird { width: 26px; }
  .bird-flight--4 { top: 7%; }
  .bird-flight--4 .bird { width: 15px; }

  @media (prefers-reduced-motion: reduce) {
    .bird-flight {
      opacity: 0;
    }
  }
</style>

<script is:inline>
  (function () {
    var container = document.querySelector('.birds');
    if (!container || container.dataset.animated) return;
    container.dataset.animated = 'true';

    if (
      window.matchMedia &&
      matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      return;
    }

    if (!Element.prototype.animate) return;

    // Flight paths — gentle vertical sway across the viewport, fading in/out
    // at the edges so birds materialize and dematerialize.
    var flightLTR = [
      { transform: 'translate(-12vw, 0)', opacity: 0, offset: 0 },
      { opacity: 0.85, offset: 0.04 },
      { transform: 'translate(15vw, -6px)', offset: 0.2 },
      { transform: 'translate(35vw, 4px)', offset: 0.4 },
      { transform: 'translate(55vw, -10px)', offset: 0.6 },
      { transform: 'translate(78vw, 2px)', offset: 0.8 },
      { opacity: 0.85, offset: 0.96 },
      { transform: 'translate(110vw, -4px)', opacity: 0, offset: 1 },
    ];

    var flightRTL = [
      { transform: 'translate(110vw, 0)', opacity: 0, offset: 0 },
      { opacity: 0.85, offset: 0.04 },
      { transform: 'translate(85vw, -7px)', offset: 0.2 },
      { transform: 'translate(60vw, 5px)', offset: 0.4 },
      { transform: 'translate(38vw, -10px)', offset: 0.6 },
      { transform: 'translate(15vw, 3px)', offset: 0.8 },
      { opacity: 0.85, offset: 0.96 },
      { transform: 'translate(-12vw, -5px)', opacity: 0, offset: 1 },
    ];

    var flapKeyframes = [
      { transform: 'scaleY(1)', offset: 0 },
      { transform: 'scaleY(0.45)', offset: 0.5 },
      { transform: 'scaleY(1)', offset: 1 },
    ];

    var lanes = [
      { sel: '.bird-flight--1', dir: flightLTR, dur: 55000, delay: -20000, flap: 320 },
      { sel: '.bird-flight--2', dir: flightLTR, dur: 70000, delay: 6000, flap: 400 },
      { sel: '.bird-flight--3', dir: flightRTL, dur: 65000, delay: 22000, flap: 360 },
      { sel: '.bird-flight--4', dir: flightLTR, dur: 85000, delay: 42000, flap: 450 },
    ];

    lanes.forEach(function (lane) {
      var el = container.querySelector(lane.sel);
      if (!el) return;
      el.animate(lane.dir, {
        duration: lane.dur,
        delay: lane.delay,
        iterations: Infinity,
        easing: 'linear',
      });
      var inner = el.querySelector('.bird');
      if (inner) {
        inner.animate(flapKeyframes, {
          duration: lane.flap,
          iterations: Infinity,
          easing: 'linear',
        });
      }
    });
  })();
</script>
