---
// Tiny birds that occasionally drift past in the far background.
// Pure CSS: no JS. Long durations + staggered (sometimes negative) delays
// give the "occasional" feel — sometimes there's nothing in the sky, then a bird,
// then maybe two. Flight path includes a gentle vertical sway so the motion
// doesn't look mechanical. Wing-flap is a separate transform on the inner SVG.
//
// Sits BEHIND the cloud layer (clouds will pass over the birds, occluding them
// briefly — exactly what you want).
---

<div class="birds" aria-hidden="true">
  <svg width="0" height="0" style="position: absolute" focusable="false">
    <!-- Four distinct silhouettes. All share the same 20x8 viewBox so sizing
         and the wing-flap (scaleY) animation work uniformly. -->

    <!-- Gull: sharp upturned M, dramatic wing peaks. -->
    <symbol id="bird-gull" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 Q 4.5,0.5 10,5 Q 15.5,0.5 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </symbol>

    <!-- Glider: gentle, soaring hawk. Wings barely raised. -->
    <symbol id="bird-glider" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 Q 5,2.2 10,4.5 Q 15,2.2 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </symbol>

    <!-- Swallow: angular zigzag, sharp wing tips, fast and pointy. -->
    <symbol id="bird-swallow" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 L 5,1.5 L 10,5 L 15,1.5 L 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="miter"
        stroke-miterlimit="2"
      />
    </symbol>

    <!-- Sparrow: small bird with a body. Two short wing arcs + a body mark. -->
    <symbol id="bird-sparrow" viewBox="0 0 20 8" preserveAspectRatio="xMidYMid meet">
      <path
        d="M 0,5 Q 4,2 8.5,4.5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
      />
      <path
        d="M 11.5,4.5 Q 16,2 20,5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
      />
      <ellipse cx="10" cy="4.7" rx="1.6" ry="1.2" fill="currentColor" />
    </symbol>
  </svg>

  <div class="bird-flight bird-flight--1">
    <svg class="bird"><use href="#bird-gull" /></svg>
  </div>
  <div class="bird-flight bird-flight--2">
    <svg class="bird"><use href="#bird-swallow" /></svg>
  </div>
  <div class="bird-flight bird-flight--3">
    <svg class="bird"><use href="#bird-glider" /></svg>
  </div>
  <div class="bird-flight bird-flight--4">
    <svg class="bird"><use href="#bird-sparrow" /></svg>
  </div>
</div>

<style>
  .birds {
    position: fixed;
    inset: 0 0 35% 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
    color: var(--color-sky-deep);
  }

  .bird-flight {
    position: absolute;
    left: 0;
    opacity: 0;
    will-change: transform, opacity;
    animation-iteration-count: infinite;
    animation-timing-function: linear;
  }

  .bird {
    display: block;
    width: 22px;
    height: auto;
    transform-origin: center;
    animation: bird-flap 0.32s linear infinite;
  }

  /* Four lanes — different heights, sizes, speeds, directions. Delays kept short
     enough that you see a bird every 10-25s on average. */
  .bird-flight--1 {
    top: 22%;
    animation-name: bird-flight-ltr;
    animation-duration: 55s;
    animation-delay: -20s;
  }

  .bird-flight--2 {
    top: 11%;
    animation-name: bird-flight-ltr;
    animation-duration: 70s;
    animation-delay: 6s;
  }
  .bird-flight--2 .bird {
    width: 17px;
    animation-duration: 0.4s;
  }

  .bird-flight--3 {
    top: 30%;
    animation-name: bird-flight-rtl;
    animation-duration: 65s;
    animation-delay: 22s;
  }
  .bird-flight--3 .bird {
    width: 26px;
    animation-duration: 0.36s;
  }

  .bird-flight--4 {
    top: 7%;
    animation-name: bird-flight-ltr;
    animation-duration: 85s;
    animation-delay: 42s;
  }
  .bird-flight--4 .bird {
    width: 15px;
    animation-duration: 0.45s;
  }

  /* Flight: drift across with a gentle vertical sway. Fade in at the start,
     fade out at the end so birds materialize/dematerialize at the edges.
     Peak opacity 0.85 — visible against both the deep-navy load state and the
     final sky blue. */
  @keyframes bird-flight-ltr {
    0%   { transform: translate(-12vw, 0); opacity: 0; }
    4%   { opacity: 0.85; }
    20%  { transform: translate(15vw, -6px); }
    40%  { transform: translate(35vw, 4px); }
    60%  { transform: translate(55vw, -10px); }
    80%  { transform: translate(78vw, 2px); }
    96%  { opacity: 0.85; }
    100% { transform: translate(110vw, -4px); opacity: 0; }
  }

  @keyframes bird-flight-rtl {
    0%   { transform: translate(110vw, 0); opacity: 0; }
    4%   { opacity: 0.85; }
    20%  { transform: translate(85vw, -7px); }
    40%  { transform: translate(60vw, 5px); }
    60%  { transform: translate(38vw, -10px); }
    80%  { transform: translate(15vw, 3px); }
    96%  { opacity: 0.85; }
    100% { transform: translate(-12vw, -5px); opacity: 0; }
  }

  /* Wing-flap: vertical squash + slight skew, gives the sense of wings beating. */
  @keyframes bird-flap {
    0%, 100% { transform: scaleY(1); }
    50%      { transform: scaleY(0.45); }
  }

  @media (prefers-reduced-motion: reduce) {
    .bird-flight,
    .bird {
      animation: none;
    }
    .bird-flight {
      opacity: 0;
    }
  }
</style>
