---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Clouds from './Clouds.astro';
import Birds from './Birds.astro';

interface Props {
  title: string;
  description?: string;
  showClouds?: boolean;
}

const {
  title,
  description = 'Systems, essays, and design experiments by James Allen Brown.',
  showClouds = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const currentPath = Astro.url.pathname;
const inSection = (prefix: string) =>
  prefix === '/' ? currentPath === '/' : currentPath.startsWith(prefix);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#71acd6" />
    <ClientRouter />
  </head>
  <body>
    <div class="sky-pulse" transition:persist="sky-pulse" aria-hidden="true"></div>
    {showClouds && <Birds />}
    {showClouds && <Clouds />}
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header" transition:persist="site-header">
      <a href="/" class="wordmark">jato</a>
      <nav aria-label="Primary">
        <a href="/writing/">Writing</a>
        <a href="/systems/">Systems</a>
        <a href="/experiments/">Experiments</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <div class="page-card paper-surface">
      <main id="main" class="site-main">
        <slot />
      </main>
      <footer class="site-footer" transition:persist="site-footer">
        <div class="footer-row">
          <p class="links">
            <a href="https://github.com/jato">GitHub</a>
            <span aria-hidden="true">·</span>
            <a href="https://www.linkedin.com/in/jamesallenbrown">LinkedIn</a>
            <span aria-hidden="true">·</span>
            <a href="mailto:jatobrown@gmail.com">Email</a>
          </p>
          <p class="archive-link"><a href="/archive/">Earlier work →</a></p>
        </div>
      </footer>
    </div>

    <aside
      class="rail-nav"
      data-rail-nav
      transition:persist="rail-nav"
      aria-label="Section navigation"
    >
      <a
        href="/"
        class="rail-wordmark"
        aria-current={inSection('/') ? 'page' : undefined}>jato</a>
      <nav>
        <a
          href="/writing/"
          aria-current={inSection('/writing/') ? 'page' : undefined}
          >Writing</a>
        <a
          href="/systems/"
          aria-current={inSection('/systems/') ? 'page' : undefined}
          >Systems</a>
        <a
          href="/experiments/"
          aria-current={inSection('/experiments/') ? 'page' : undefined}
          >Experiments</a>
        <a
          href="/about/"
          aria-current={inSection('/about/') ? 'page' : undefined}>About</a>
        <a
          href="/archive/"
          aria-current={inSection('/archive/') ? 'page' : undefined}
          >Archive</a>
      </nav>
    </aside>

    <script is:inline>
      // Drive the sky-pulse fade via the Web Animations API so it can't be
      // restarted by CSS re-evaluation when ClientRouter swaps stylesheets.
      // The .sky-pulse element is transition:persist'd, so the same DOM node
      // (and its running animation) carries through every navigation. The
      // dataset flag ensures the animation only kicks off once per full load.
      (function () {
        var sp = document.querySelector('.sky-pulse');
        if (!sp || sp.dataset.pulsed) return;
        sp.dataset.pulsed = 'true';
        if (
          window.matchMedia &&
          matchMedia('(prefers-reduced-motion: reduce)').matches
        ) {
          return;
        }
        if (!sp.animate) return; // very old browser fallback: no pulse, just static sky
        sp.style.opacity = '1';
        sp.animate(
          [{ opacity: 1 }, { opacity: 0 }],
          { duration: 12000, easing: 'ease-out', fill: 'forwards' }
        );
      })();

      // Wire IntersectionObserver once. Rail + header both transition:persist
      // so the observer keeps watching across ClientRouter navigations.
      (function () {
        var rail = document.querySelector('[data-rail-nav]');
        var header = document.querySelector('.site-header');
        if (!rail || !header) return;

        if (!rail.dataset.wired) {
          rail.dataset.wired = 'true';
          if ('IntersectionObserver' in window) {
            new IntersectionObserver(
              function (entries) {
                rail.classList.toggle('is-visible', !entries[0].isIntersecting);
              },
              { threshold: 0, rootMargin: '0px 0px -10% 0px' }
            ).observe(header);
          } else {
            rail.classList.add('is-visible');
          }
        }

        // Immediate check (fires before the observer in case page is already scrolled)
        var rect = header.getBoundingClientRect();
        var headerVisible = rect.bottom > 0 && rect.top < window.innerHeight;
        rail.classList.toggle('is-visible', !headerVisible);
      })();

      // Update active-nav highlight on every page-load (URL-dependent).
      function updateRailActive() {
        var rail = document.querySelector('[data-rail-nav]');
        if (!rail) return;
        var path = location.pathname;
        rail.querySelectorAll('a').forEach(function (a) {
          var href = a.getAttribute('href') || '';
          var matches = href === '/' ? path === '/' : path.startsWith(href);
          if (matches) a.setAttribute('aria-current', 'page');
          else a.removeAttribute('aria-current');
        });
      }
      updateRailActive();
      document.addEventListener('astro:page-load', updateRailActive);

      // Single global rAF controller drives clouds + birds. Replaces WAAPI
      // because iOS Safari pauses WAAPI animations on persisted elements
      // during ClientRouter navigations and won't resume on .play(). rAF is
      // tied to document visibility (throttled, not paused, while visible),
      // so animations keep advancing across SPA navigations.
      (function () {
        if (window.__skyAnim) return;
        if (
          window.matchMedia &&
          matchMedia('(prefers-reduced-motion: reduce)').matches
        ) {
          window.__skyAnim = { active: false };
          return;
        }
        window.__skyAnim = { active: true };

        var startTime = 0;

        // Clouds: durations match 2015 site parallax timings.
        var cloudDurations = [13500, 8000, 9200, 20500, 11200];

        // Birds: dur/delay/direction match the previous WAAPI lane config.
        // Negative delay = "already N ms into first cycle on load".
        var birdLanes = [
          { sel: '.bird-flight--1', dur: 55000, delay: -20000, rtl: false, flap: 320 },
          { sel: '.bird-flight--2', dur: 70000, delay: 6000, rtl: false, flap: 400 },
          { sel: '.bird-flight--3', dur: 65000, delay: 22000, rtl: true, flap: 360 },
          { sel: '.bird-flight--4', dur: 85000, delay: 42000, rtl: false, flap: 450 },
        ];

        // Flight keyframes: x in vw, y in px, opacity 0..0.85.
        var flightLTR = [
          { o: 0,    x: -12, y: 0,   a: 0 },
          { o: 0.04, x: -8,  y: 0,   a: 0.85 },
          { o: 0.2,  x: 15,  y: -6,  a: 0.85 },
          { o: 0.4,  x: 35,  y: 4,   a: 0.85 },
          { o: 0.6,  x: 55,  y: -10, a: 0.85 },
          { o: 0.8,  x: 78,  y: 2,   a: 0.85 },
          { o: 0.96, x: 105, y: -3,  a: 0.85 },
          { o: 1,    x: 110, y: -4,  a: 0 },
        ];
        var flightRTL = [
          { o: 0,    x: 110, y: 0,   a: 0 },
          { o: 0.04, x: 106, y: 0,   a: 0.85 },
          { o: 0.2,  x: 85,  y: -7,  a: 0.85 },
          { o: 0.4,  x: 60,  y: 5,   a: 0.85 },
          { o: 0.6,  x: 38,  y: -10, a: 0.85 },
          { o: 0.8,  x: 15,  y: 3,   a: 0.85 },
          { o: 0.96, x: -8,  y: -3,  a: 0.85 },
          { o: 1,    x: -12, y: -5,  a: 0 },
        ];

        function lerp(a, b, u) { return a + (b - a) * u; }

        function interpFlight(kf, t) {
          var prev = kf[0], curr = kf[kf.length - 1];
          for (var i = 1; i < kf.length; i++) {
            if (kf[i].o >= t) {
              prev = kf[i - 1];
              curr = kf[i];
              break;
            }
          }
          var u = (t - prev.o) / (curr.o - prev.o || 1);
          return {
            x: lerp(prev.x, curr.x, u),
            y: lerp(prev.y, curr.y, u),
            a: lerp(prev.a, curr.a, u),
          };
        }

        function tick(now) {
          if (!startTime) startTime = now;
          var t = now - startTime;

          var clouds = document.querySelectorAll('.cloud');
          for (var ci = 0; ci < clouds.length; ci++) {
            var dur = cloudDurations[ci] || 8000;
            var phase = (t % dur) / dur;
            var x = 300 - 1400 * phase;
            var op;
            if (phase < 0.1) op = lerp(0.08, 0.5, phase / 0.1);
            else if (phase < 0.9) op = lerp(0.5, 0, (phase - 0.1) / 0.8);
            else op = 0;
            clouds[ci].style.transform = 'translateX(' + x.toFixed(2) + 'px)';
            clouds[ci].style.opacity = op.toFixed(3);
          }

          for (var li = 0; li < birdLanes.length; li++) {
            var lane = birdLanes[li];
            var el = document.querySelector(lane.sel);
            if (!el) continue;
            var animTime = t - lane.delay;
            if (animTime < 0) {
              el.style.opacity = '0';
              continue;
            }
            var bphase = (animTime % lane.dur) / lane.dur;
            var f = interpFlight(lane.rtl ? flightRTL : flightLTR, bphase);
            el.style.transform = 'translate(' + f.x.toFixed(2) + 'vw, ' + f.y.toFixed(2) + 'px)';
            el.style.opacity = f.a.toFixed(3);

            var inner = el.querySelector('.bird');
            if (inner) {
              var fphase = (t % lane.flap) / lane.flap;
              var sy = fphase < 0.5
                ? lerp(1, 0.45, fphase / 0.5)
                : lerp(0.45, 1, (fphase - 0.5) / 0.5);
              inner.style.transform = 'scaleY(' + sy.toFixed(3) + ')';
            }
          }

          requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
      })();
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip-link:focus {
        left: var(--space-4);
        top: var(--space-4);
        background: var(--color-paper);
        color: var(--color-ink);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-sm);
        z-index: 100;
      }

      .site-header {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-6);
        padding: var(--space-6) var(--space-6) var(--space-8);
        max-width: 980px;
        margin: 0 auto;
        color: var(--color-sky-ink);
      }

      .wordmark {
        font-family: var(--font-serif);
        font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;
        font-weight: 460;
        font-size: 1.6rem;
        line-height: 1;
        text-decoration: none;
        color: var(--color-sky-ink);
        letter-spacing: -0.01em;
      }

      .site-header nav {
        display: flex;
        gap: var(--space-5);
        flex-wrap: wrap;
      }

      .site-header nav a {
        text-decoration: none;
        color: var(--color-sky-ink-soft);
        font-size: 0.95rem;
        letter-spacing: 0.005em;
      }

      .site-header nav a:hover,
      .site-header nav a[aria-current='page'] {
        color: var(--color-sky-ink);
        text-decoration: underline;
        text-underline-offset: 0.25em;
      }

      .page-card {
        position: relative;
        z-index: 5;
        max-width: 980px;
        margin: 0 auto var(--space-10);
        background: var(--color-paper);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-card);
        overflow: hidden;
      }

      .site-main {
        padding: var(--space-12) var(--space-8) var(--space-10);
      }

      .site-footer {
        padding: var(--space-6) var(--space-8) var(--space-8);
        color: var(--color-ink-muted);
        font-size: 0.9rem;
        border-top: 1px solid var(--color-rule);
      }

      .footer-row {
        display: flex;
        justify-content: space-between;
        gap: var(--space-4);
        flex-wrap: wrap;
      }

      .footer-row p {
        margin: 0;
        max-width: none;
      }

      .links span {
        margin: 0 var(--space-2);
        opacity: 0.55;
      }

      .archive-link a {
        text-decoration: none;
        color: var(--color-ink-soft);
      }

      .archive-link a:hover {
        text-decoration: underline;
      }

      .rail-nav {
        position: fixed;
        top: 50%;
        right: 0;
        transform: translate(8px, -50%);
        z-index: 30;
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        padding: var(--space-4) var(--space-5);
        background: rgba(246, 241, 231, 0.92);
        backdrop-filter: blur(10px) saturate(1.2);
        -webkit-backdrop-filter: blur(10px) saturate(1.2);
        border: 1px solid var(--color-rule);
        border-right: none;
        border-radius: 14px 0 0 14px;
        box-shadow: 0 4px 18px -4px rgba(21, 24, 43, 0.15);
        opacity: 0;
        transition: opacity 0.3s ease, transform 0.3s ease;
        pointer-events: none;
      }
      .rail-nav.is-visible {
        opacity: 1;
        transform: translate(0, -50%);
        pointer-events: auto;
      }
      .rail-wordmark {
        font-family: var(--font-serif);
        font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;
        font-weight: 460;
        font-size: 1.15rem;
        line-height: 1;
        text-decoration: none;
        color: var(--color-ink);
        padding-bottom: var(--space-3);
        border-bottom: 1px solid var(--color-rule);
      }
      .rail-nav nav {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }
      .rail-nav nav a {
        font-family: var(--font-sans);
        font-size: 0.85rem;
        letter-spacing: 0.02em;
        text-decoration: none;
        color: var(--color-ink-soft);
        padding: 2px 0;
      }
      .rail-nav nav a:hover {
        color: var(--color-ink);
      }
      .rail-nav nav a[aria-current='page'] {
        color: var(--color-ink);
        font-weight: 500;
      }
      .rail-wordmark[aria-current='page'] {
        color: var(--color-accent);
      }

      @media (prefers-reduced-motion: reduce) {
        .rail-nav {
          transition: opacity 0.15s linear;
          transform: translate(0, -50%);
        }
      }

      /* Narrow viewports: rail becomes a horizontal pill at bottom-center
         so it doesn't overlap the page-card content. Hidden entirely on
         very small screens. */
      @media (max-width: 700px) {
        .site-header {
          flex-direction: column;
          gap: var(--space-3);
          align-items: flex-start;
          padding: var(--space-5) var(--space-5) var(--space-6);
        }
        .rail-nav {
          top: auto;
          right: 50%;
          bottom: var(--space-4);
          transform: translate(50%, 8px);
          flex-direction: row;
          align-items: center;
          gap: var(--space-3);
          padding: var(--space-2) var(--space-4);
          border-right: 1px solid var(--color-rule);
          border-radius: 999px;
          font-size: 0.85rem;
          max-width: calc(100vw - var(--space-5));
        }
        .rail-nav.is-visible {
          transform: translate(50%, 0);
        }
        .rail-wordmark {
          padding-bottom: 0;
          padding-right: var(--space-3);
          border-bottom: none;
          border-right: 1px solid var(--color-rule);
          font-size: 1rem;
        }
        .rail-nav nav {
          flex-direction: row;
          gap: var(--space-4);
        }
        .rail-nav nav a {
          font-size: 0.82rem;
          white-space: nowrap;
        }
        .page-card {
          margin-left: var(--space-3);
          margin-right: var(--space-3);
        }
        .site-main {
          padding: var(--space-8) var(--space-5) var(--space-6);
        }
        .site-footer {
          padding: var(--space-5);
        }
        .footer-row {
          flex-direction: column;
        }
      }

      /* Phones: keep the pill visible. Tighten gaps and font, drop the
         secondary "Archive" link (still reachable via footer "Earlier work").
         Allow horizontal scroll as a final fallback so nothing gets clipped. */
      @media (max-width: 480px) {
        .rail-nav {
          gap: var(--space-2);
          padding: 6px var(--space-3);
          max-width: calc(100vw - var(--space-3));
          overflow-x: auto;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
        }
        .rail-nav::-webkit-scrollbar {
          display: none;
        }
        .rail-wordmark {
          font-size: 0.95rem;
          padding-right: var(--space-2);
        }
        .rail-nav nav {
          gap: var(--space-3);
        }
        .rail-nav nav a {
          font-size: 0.78rem;
        }
        /* Drop Archive on very narrow widths — it's reachable via footer. */
        .rail-nav nav a[href='/archive/'] {
          display: none;
        }
      }

      /* Below ~340px, also drop About. About is reachable via the page-card
         header on first load. */
      @media (max-width: 340px) {
        .rail-nav nav a[href='/about/'] {
          display: none;
        }
      }
    </style>
  </body>
</html>
