---
import '../styles/global.css';
import Clouds from './Clouds.astro';
import Birds from './Birds.astro';

interface Props {
  title: string;
  description?: string;
  showClouds?: boolean;
}

const {
  title,
  description = 'James Allen Brown — systems, essays, design experiments.',
  showClouds = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#71acd6" />
  </head>
  <body>
    {showClouds && <Birds />}
    {showClouds && <Clouds />}
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <a href="/" class="wordmark">jato</a>
      <nav aria-label="Primary">
        <a href="/writing/">Writing</a>
        <a href="/systems/">Systems</a>
        <a href="/experiments/">Experiments</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <div class="page-card paper-surface">
      <main id="main" class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-row">
          <p class="links">
            <a href="https://github.com/jato">GitHub</a>
            <span aria-hidden="true">·</span>
            <a href="https://www.linkedin.com/in/jamesallenbrown">LinkedIn</a>
            <span aria-hidden="true">·</span>
            <a href="mailto:jatobrown@gmail.com">Email</a>
          </p>
          <p class="archive-link"><a href="/archive/">Earlier work →</a></p>
        </div>
      </footer>
    </div>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip-link:focus {
        left: var(--space-4);
        top: var(--space-4);
        background: var(--color-paper);
        color: var(--color-ink);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-sm);
        z-index: 100;
      }

      .site-header {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-6);
        padding: var(--space-6) var(--space-6) var(--space-8);
        max-width: 980px;
        margin: 0 auto;
        color: var(--color-sky-ink);
      }

      .wordmark {
        font-family: var(--font-serif);
        font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;
        font-weight: 460;
        font-size: 1.6rem;
        line-height: 1;
        text-decoration: none;
        color: var(--color-sky-ink);
        letter-spacing: -0.01em;
      }

      .site-header nav {
        display: flex;
        gap: var(--space-5);
        flex-wrap: wrap;
      }

      .site-header nav a {
        text-decoration: none;
        color: var(--color-sky-ink-soft);
        font-size: 0.95rem;
        letter-spacing: 0.005em;
      }

      .site-header nav a:hover,
      .site-header nav a[aria-current='page'] {
        color: var(--color-sky-ink);
        text-decoration: underline;
        text-underline-offset: 0.25em;
      }

      .page-card {
        position: relative;
        z-index: 5;
        max-width: 980px;
        margin: 0 auto var(--space-10);
        background: var(--color-paper);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-card);
        overflow: hidden;
      }

      .site-main {
        padding: var(--space-12) var(--space-8) var(--space-10);
      }

      .site-footer {
        padding: var(--space-6) var(--space-8) var(--space-8);
        color: var(--color-ink-muted);
        font-size: 0.9rem;
        border-top: 1px solid var(--color-rule);
      }

      .footer-row {
        display: flex;
        justify-content: space-between;
        gap: var(--space-4);
        flex-wrap: wrap;
      }

      .footer-row p {
        margin: 0;
        max-width: none;
      }

      .links span {
        margin: 0 var(--space-2);
        opacity: 0.55;
      }

      .archive-link a {
        text-decoration: none;
        color: var(--color-ink-soft);
      }

      .archive-link a:hover {
        text-decoration: underline;
      }

      @media (max-width: 700px) {
        .site-header {
          flex-direction: column;
          gap: var(--space-3);
          align-items: flex-start;
          padding: var(--space-5) var(--space-5) var(--space-6);
        }
        .page-card {
          margin-left: var(--space-3);
          margin-right: var(--space-3);
        }
        .site-main {
          padding: var(--space-8) var(--space-5) var(--space-6);
        }
        .site-footer {
          padding: var(--space-5);
        }
        .footer-row {
          flex-direction: column;
        }
      }
    </style>
  </body>
</html>
