---
// Ports the cloud parallax system from the 2015 site (jato.github.io/stylesheets/landing.css:191-315).
// Animation driven via Web Animations API (not CSS) so the running animations
// survive ClientRouter navigations on this transition:persist'd element.
// CSS-driven animations on persistent elements get restarted by stylesheet
// re-evaluation; WAAPI animations are tied to the JS Animation object and
// are unaffected.
// Single SVG <symbol> reused via <use>, so the path only ships once.
// Respects prefers-reduced-motion.
---

<div class="clouds" aria-hidden="true" transition:persist="clouds">
  <svg width="0" height="0" style="position:absolute" focusable="false">
    <symbol id="cloud-shape" viewBox="0 0 762 331">
      <path
        fill="currentColor"
        d="M715.394,228h-16.595c0.79-5.219,1.201-10.562,1.201-16c0-58.542-47.458-106-106-106
        c-8.198,0-16.178,0.932-23.841,2.693C548.279,45.434,488.199,0,417.5,0c-84.827,0-154.374,65.401-160.98,148.529
        C245.15,143.684,232.639,141,219.5,141c-49.667,0-90.381,38.315-94.204,87H46.607C20.866,228,0,251.058,0,279.5
        S20.866,331,46.607,331h668.787C741.133,331,762,307.942,762,279.5S741.133,228,715.394,228z"
      />
    </symbol>
  </svg>

  <svg class="cloud cloud--big cloud--front cloud--slowest"><use href="#cloud-shape" /></svg>
  <svg class="cloud cloud--smaller cloud--distant"><use href="#cloud-shape" /></svg>
  <svg class="cloud cloud--small cloud--slow"><use href="#cloud-shape" /></svg>
  <svg class="cloud cloud--massive cloud--distant cloud--super-slow"><use href="#cloud-shape" /></svg>
  <svg class="cloud cloud--slower"><use href="#cloud-shape" /></svg>
</div>

<style>
  .clouds {
    position: fixed;
    inset: 0 0 50% 0;
    overflow: hidden;
    pointer-events: none;
    color: #ffffff;
    z-index: 0;
    transform: translateZ(0);
  }

  .cloud {
    position: absolute;
    top: 4%;
    right: 0;
    width: 300px;
    height: auto;
    opacity: 0;
  }

  .cloud--front { z-index: 9; }
  .cloud--distant { z-index: 1; }

  .cloud--smaller {
    width: 100px;
    margin-right: 400px;
    margin-top: 50px;
  }
  .cloud--small {
    width: 150px;
    margin-right: 200px;
  }
  .cloud--big {
    width: 500px;
    margin-top: 50px;
    margin-right: 150px;
  }
  .cloud--massive {
    width: 600px;
    margin-top: 20px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cloud {
      opacity: 0.35;
      transform: translateX(-200px);
    }
  }
</style>

<script is:inline>
  (function () {
    var container = document.querySelector('.clouds');
    if (!container || container.dataset.animated) return;
    container.dataset.animated = 'true';

    if (
      window.matchMedia &&
      matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      return;
    }

    var clouds = container.querySelectorAll('.cloud');
    // Durations match the original 2015 cloud parallax timings.
    var durations = [13500, 8000, 9200, 20500, 11200];

    var keyframes = [
      { transform: 'translateX(300px)', opacity: 0.08, offset: 0 },
      { opacity: 0.5, offset: 0.1 },
      { opacity: 0, offset: 0.9 },
      { transform: 'translateX(-1100px)', opacity: 0, offset: 1 },
    ];

    clouds.forEach(function (cloud, i) {
      if (!cloud.animate) return;
      cloud.animate(keyframes, {
        duration: durations[i] || 8000,
        iterations: Infinity,
        easing: 'linear',
      });
    });
  })();
</script>
